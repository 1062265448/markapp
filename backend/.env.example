# MarkApp Backend Environment Variables
# 复制为 .env 后根据实际环境修改；.env 已被 .gitignore 排除

# ===== Server =====
PORT=3003
NODE_ENV=production

# ===== API Key Authentication (machine-to-machine) =====
# 留空则禁用 API Key 校验（仅依赖用户 JWT）
API_KEY=your-api-key-here
API_KEY_ENABLED=true

# ===== User Login =====
# 演示账号：未配置时回退为 admin / admin123（仅供开发）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-in-production
# Token 签名密钥：生产必须用 32 字节随机字符串
# 生成方式: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_SECRET=

# ===== Rate Limiting =====
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX=30

# ===== Trust Proxy =====
# 反向代理后部署时设为 true，从 X-Forwarded-For 取真实客户端 IP
TRUST_PROXY=false

# ===== CORS =====
# 多个 origin 用逗号分隔；空 = 禁止跨域
CORS_ORIGIN=https://mark.jcngcp.xyz

# ===== RapidOCR =====
RAPID_OCR_URL=http://localhost:8866

# ===== Image Validation =====
MAX_IMAGE_SIZE=10485760

# ===== MySQL =====
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USERNAME=root
MYSQL_PASSWORD=
MYSQL_DATABASE=markapp

# ===== Image Storage =====
IMAGE_UPLOAD_DIR=uploads
IMAGE_RETENTION_DAYS=10
