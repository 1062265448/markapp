# MarkApp Backend Environment Variables

# Server
PORT=3003
NODE_ENV=production

# API Key Authentication
API_KEY=your-api-key-here
API_KEY_ENABLED=true

# Rate Limiting
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX=10

# CORS — comma-separated origins (leave empty to block all cross-origin)
CORS_ORIGIN=

# Qwen AI (Alibaba Cloud)
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Volc Engine (ByteDance)
VOLC_API_KEY=
VOLC_BASE_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions
VOLC_MODEL=doubao-1-5-vision-pro-32k-250115

# GLM AI (Zhipu) - supports up to 3 keys for rotation
GLM_API_KEY=
GLM_API_KEY_2=
GLM_API_KEY_3=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions

# RapidOCR
RAPID_OCR_URL=http://localhost:8866

# Image Validation
MAX_IMAGE_SIZE=10485760

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USERNAME=markapp
MYSQL_PASSWORD=
MYSQL_DATABASE=markapp

# Image Storage
IMAGE_UPLOAD_DIR=uploads
IMAGE_RETENTION_DAYS=10
