# MarkApp Backend Environment Variables

# Server
PORT=3003
NODE_ENV=production

# API Key Authentication
API_KEY=your-api-key-here
API_KEY_ENABLED=true

# Rate Limiting
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX=30

# CORS — comma-separated origins (leave empty to block all cross-origin)
CORS_ORIGIN=

# RapidOCR
RAPID_OCR_URL=http://localhost:8866

# Image Validation
MAX_IMAGE_SIZE=10485760

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USERNAME=root
MYSQL_PASSWORD=
MYSQL_DATABASE=markapp

# Image Storage
IMAGE_UPLOAD_DIR=uploads
IMAGE_RETENTION_DAYS=10
